# Groq API (used for question generation and grading)
# Create a key: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# Google Gemini API (optional — admin can choose Gemini for question generation)
# Create a key: https://aistudio.google.com/apikey
# GOOGLE_API_KEY1=your_google_api_key_here
# Optional: prepend one model (rest of default chain still tried on failure)
# GEMINI_MODEL=gemini-3.1-pro-preview
# Optional: replace entire fallback chain (comma-separated, in try order)
# GEMINI_MODEL_CHAIN=gemini-3.1-pro-preview,gemini-3.5-flash,gemini-3-flash-preview,gemini-2.5-flash

# ---------------------------------------------------------------------------
# Auth & security
# ---------------------------------------------------------------------------
# Long random string for JWT signing (required for admin and client login)
JWT_SECRET=change-me-long-random-string

# Admin portal password — plain text (dev) or bcrypt hash $2b$... (production)
ADMIN_PASSWORD=change-me

# Per-IP rate limiting on sensitive endpoints (login, submit, generate)
RATE_LIMIT_ENABLED=true

# Set to true when serving over HTTPS in production (adds HSTS header)
ENABLE_HSTS=false

# Audit log level and optional file path (JSON lines to stdout if unset)
AUDIT_LOG_LEVEL=INFO
# AUDIT_LOG_FILE=logs/audit.log

# Optional: model id (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# ---------------------------------------------------------------------------
# MongoDB Atlas (primary database)
# Example: mongodb+srv://user:pass@cluster.mongodb.net/assesment?retryWrites=true&w=majority
# ---------------------------------------------------------------------------
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/assesment?retryWrites=true&w=majority
# Optional — database name (default: parsed from URI path, or assesment)
# MONGODB_DB_NAME=assesment

# Auto-seed default catalog on API startup when empty (default true). Set false in production if you manage catalog manually.
# AUTO_SEED_CATALOG=true

# Tests always use database test_db (see tests/conftest.py); no separate config needed.

# Stage 12 — focus topic threshold (percent); default 75
# FOCUS_TOPIC_PERCENT_THRESHOLD=75

# Public app URL for certificate share links (default http://localhost:5173)
# APP_PUBLIC_URL=https://your-app.example.com

# Issuer name shown on verification pages and LinkedIn share (fallback if not set in admin)
# CERTIFICATE_ORG_NAME=Wekan Enterprise Solutions
