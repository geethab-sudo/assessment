# Groq API (used for question generation and grading)
# Create a key: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# ---------------------------------------------------------------------------
# Auth & security
# ---------------------------------------------------------------------------
# Long random string for JWT signing (required for admin and client login)
JWT_SECRET=change-me-long-random-string

# Admin portal password — plain text (dev) or bcrypt hash $2b$... (production)
ADMIN_PASSWORD=change-me

# Per-IP rate limiting on sensitive endpoints (login, submit, generate)
RATE_LIMIT_ENABLED=true

# Set to true when serving over HTTPS in production (adds HSTS header)
ENABLE_HSTS=false

# Audit log level and optional file path (JSON lines to stdout if unset)
AUDIT_LOG_LEVEL=INFO
# AUDIT_LOG_FILE=logs/audit.log

# Optional: model id (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# ---------------------------------------------------------------------------
# Docker: PostgreSQL (read by `docker compose` and by you for DATABASE_URL)
# Start DB:  docker compose up -d
# ---------------------------------------------------------------------------
# Credentials and database name — must match DATABASE_URL below.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=assesment
# Port published on the host (default 5433 in docker-compose; avoids conflict with local Postgres on 5432)
POSTGRES_PORT=5433
# For API on your machine, use 127.0.0.1. If the API ever runs in Compose, use host "db".
POSTGRES_HOST=127.0.0.1

# ---------------------------------------------------------------------------
# App database URL (SQLAlchemy). Match user/password/db/port to how you run Postgres.
# Docker Compose (use port from POSTGRES_PORT, usually 5433):
# ---------------------------------------------------------------------------
# DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5433/assesment

# ---------------------------------------------------------------------------
# Authentication (required for admin routes)
# Generate JWT secret: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Generate admin password hash:
#   python3 -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
# ---------------------------------------------------------------------------
# JWT_SECRET=your-long-random-secret
# ADMIN_PASSWORD=$2b$12$...bcrypt-hash-or-plain-text-for-local-dev-only

# ---------------------------------------------------------------------------
# Security (optional)
# ---------------------------------------------------------------------------
# RATE_LIMIT_ENABLED=true
# ENABLE_HSTS=false
# AUDIT_LOG_LEVEL=INFO
# AUDIT_LOG_FILE=audit.log

# Local Postgres without Docker (example — adjust user and omit password if using peer auth):
# POSTGRES_USER=myuser
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5432
# POSTGRES_DB=assesment
# DATABASE_URL=postgresql+psycopg://myuser@127.0.0.1:5432/assesment
